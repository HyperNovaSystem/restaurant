{
  "name": "restaurant",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "DOMECS exemplar — real-time restaurant floor simulation (customers, waiters, tables, tips).",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "test": "tsc --noEmit && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "deploy": "vite build && gh-pages -d dist"
  },
  "dependencies": {
    "@domecs/core": "file:../domecs/packages/domecs",
    "@domecs/dom": "file:../domecs/packages/domecs-dom",
    "@domecs/input": "file:../domecs/packages/domecs-input",
    "domecs-workspace": "file:../domecs"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "gh-pages": "^6.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
